{
  "name": "secvisogram",
  "private": true,
  "description": "Secvisogram build infrastructure",
  "version": "2.6.5",
  "scripts": {
    "dev": "cd app && npm run dev",
    "build": "cd app && npm run build",
    "test": "tsc -b . && prettier --check . && cd app && npm test",
    "postinstall": "npm run install:app && npm run install:bin",
    "lint": "cd app && eslint .",
    "install:app": "cd app && npm ci",
    "install:bin": "cd bin && npm ci",
    "generate-html-template2.0": "node bin/cli.js generate-html-template --csaf app/lib/shared/Core/csaf_2.0.json --cvss-3.1 app/lib/shared/Core/cvss-v3.1.json > app/lib/SecvisogramPage/View/shared/HTMLTemplate/Template2.0.html"
  },
  "config": {
    "port": 8080
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:secvisogram/secvisogram.git"
  },
  "keywords": [
    "CSAF",
    "Secvisogram",
    "Common Security Advisory Framework"
  ],
  "author": "eXXcellent solutions GmbH",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
